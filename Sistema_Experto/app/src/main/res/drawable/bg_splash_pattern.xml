<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fondo base con gradiente -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="160"
                android:startColor="@color/medical_primary"
                android:centerColor="@color/medical_primary_light"
                android:endColor="@color/medical_secondary" />
        </shape>
    </item>
    <!-- Patrón decorativo superior -->
    <item
        android:top="-200dp"
        android:right="-100dp">
        <shape android:shape="oval">
            <solid android:color="#20FFFFFF" />
            <size
                android:width="400dp"
                android:height="400dp" />
        </shape>
    </item>
    <!-- Patrón decorativo inferior -->
    <item
        android:bottom="-150dp"
        android:left="-100dp">
        <shape android:shape="oval">
            <solid android:color="#15FFFFFF" />
            <size
                android:width="350dp"
                android:height="350dp" />
        </shape>
    </item>
</layer-list>


