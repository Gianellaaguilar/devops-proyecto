<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/medical_card_background"
    app:strokeWidth="1dp"
    app:strokeColor="@color/medical_primary_lighter">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Foto del experto -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="3dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/medical_primary_lighter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/imageDoctor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="Foto del doctor" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Información del experto -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/cardAvatar"
            app:layout_constraintEnd_toStartOf="@+id/cardBandera">

            <TextView
                android:id="@+id/textNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dr. Giovanni Gasbarrini"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/medical_text_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/textEspecialidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gastroenterología"
                android:textSize="13sp"
                android:textColor="@color/medical_primary"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/textPais"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Italia"
                android:textSize="12sp"
                android:textColor="@color/medical_text_tertiary"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Bandera/indicador de país -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBandera"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/icon_bg_coral"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/textBandera"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="🇮🇹"
                android:textSize="18sp"
                android:gravity="center" />

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
