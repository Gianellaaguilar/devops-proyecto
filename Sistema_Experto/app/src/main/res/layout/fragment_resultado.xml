<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/medical_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header con gradiente -->
        <View
            android:id="@+id/viewHeader"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:background="@drawable/bg_header_gradient"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Icono de resultado en el header -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResultIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="📋"
                android:textSize="40sp"
                android:gravity="center" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/textTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Resultados del análisis"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/medical_text_white"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:letterSpacing="0.01"
            app:layout_constraintTop_toBottomOf="@+id/cardResultIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/textSubtitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Según tus síntomas, es muy probable que tengas:"
            android:textSize="14sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@+id/textTitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Card de enfermedad principal -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEnfermedad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp"
            android:layout_marginHorizontal="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@color/medical_tertiary"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@+id/viewHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🩺"
                    android:textSize="32sp" />

                <TextView
                    android:id="@+id/textEnfermedad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nombre de la enfermedad"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/medical_text_white"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:letterSpacing="0.02" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Card de síntomas seleccionados -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSintomas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="20dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/medical_card_background"
            app:strokeWidth="1dp"
            app:strokeColor="@color/medical_primary_lighter"
            app:layout_constraintTop_toBottomOf="@+id/cardEnfermedad"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_circle_teal" />

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="-36dp"
                        android:text="📝"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Síntomas seleccionados"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/medical_text_primary"
                        android:layout_marginStart="12dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/textSintomasSeleccionados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="– Síntoma 1\n– Síntoma 2"
                    android:textSize="14sp"
                    android:textColor="@color/medical_text_secondary"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="48dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Card de recomendaciones -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRecomendaciones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="20dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/medical_card_highlight"
            app:strokeWidth="1dp"
            app:strokeColor="@color/medical_primary_lighter"
            app:layout_constraintTop_toBottomOf="@+id/cardSintomas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_circle_coral" />

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="-36dp"
                        android:text="💊"
                        android:textSize="18sp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recomendaciones"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/medical_text_primary"
                        android:layout_marginStart="12dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/textRecomendaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Recomendación 1\n• Recomendación 2"
                    android:textSize="14sp"
                    android:textColor="@color/medical_text_secondary"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="48dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Card de advertencia -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAdvertencia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="20dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/medical_warning_background"
            app:strokeWidth="1dp"
            app:strokeColor="@color/medical_warning"
            app:layout_constraintTop_toBottomOf="@+id/cardRecomendaciones"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/textAdvertencia"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Este resultado es una estimación basada en síntomas. Si empeoras o persisten los síntomas, consulta a un profesional de salud."
                    android:textSize="13sp"
                    android:textColor="@color/medical_warning_text"
                    android:lineSpacingExtra="3dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Botones de acción -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonNuevoDiagnostico"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:text="🔄 Nuevo diagnóstico"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="20dp"
            app:cornerRadius="27dp"
            app:backgroundTint="@color/medical_primary"
            app:layout_constraintTop_toBottomOf="@+id/cardAdvertencia"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonVolverInicio"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:text="🏠 Volver al inicio"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="24dp"
            app:cornerRadius="27dp"
            app:strokeColor="@color/medical_primary"
            app:strokeWidth="2dp"
            app:backgroundTint="@android:color/transparent"
            android:textColor="@color/medical_primary"
            app:layout_constraintTop_toBottomOf="@+id/buttonNuevoDiagnostico"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="@color/medical_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
